{
  "manifest_version": 3,
  "name": "Native Messaging FFmpeg Demo",
  "description": "Native messaging demo for FFmpeg AVFoundation capture.",
  "version": "0.1.0",
  "permissions": ["nativeMessaging"],
  "action": {
    "default_title": "FFmpeg Demo",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["file://*/*", "http://*/*", "https://*/*"],
      "js": ["content-bridge.js"],
      "run_at": "document_idle"
    }
  ]
}
