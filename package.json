{
  "name": "update",
  "version": "0.1.0",
  "description": "Audio processing tool with web and Electron desktop runtime",
  "repository": {
    "type": "git",
    "url": "https://github.com/maredm/dunkadunka.se.git"
  },
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "bun build --watch src/app.ts --outdir static --minify",
    "start": "bun src/app.ts",
    "build": "bun run build:html && bun build src/app.ts --outdir static --minify",
    "build:html": "bun run scripts/render-index.mjs",
    "electron:start": "bun run build:html && electron .",
    "electron:dev": "concurrently -k -n RENDERER,ELECTRON -c auto \"bun run dev\" \"wait-on static/app.js && bun run electron:start\"",
    "electron:pack": "bun run build && electron-builder --dir",
    "electron:dist": "bun run build && electron-builder --linux AppImage deb --mac dmg zip --win nsis",
    "test": "bun test",
    "check": "tsc --noEmit"
  },
  "devDependencies": {
    "bun-types": "^1.3.14",
    "concurrently": "^9.2.1",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "nunjucks": "^3.2.4",
    "plotly.js-dist-min": "^3.6.0"
  },
  "build": {
    "appId": "se.dunkadunka.update",
    "productName": "Update",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron/**/*",
      "index.html",
      "static/**/*",
      "manifest.webmanifest",
      "sw.js",
      "package.json"
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Audio"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    }
  }
}